# ==========================================================================
# FLOW / org-ai-platform — environment variables
# Copy this file to .env (local) and configure per environment.
# For production, set these in Vercel (web) and Render (gateway + ai-engine).
# ==========================================================================

# ------ Shared ------
NODE_ENV=development

# PostgreSQL (Neon in prod). Local dev can use docker-compose postgres.
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgresql://orgai:orgai-dev-password@localhost:5432/orgai

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_minimum_32_characters_required_xxxxxxxx

# ------ LLM provider (Anthropic Claude only) ------
# プラン別モデル: STARTER → Haiku 4.5, PRO → Sonnet 4.6, MAX → Opus 4.7
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------ Service URLs (server-to-server) ------
FRONTEND_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:4000
AI_ENGINE_URL=http://localhost:8000

# ------ n8n integration (optional) ------
# N8N_CLOUD_URL=https://your-tenant.app.n8n.cloud
# N8N_API_KEY=
# N8N_WORKFLOW_ID=
# N8N_WEBHOOK_AUTH_TOKEN=

# ==========================================================================
# apps/web (Vite) build-time variables — put these in apps/web/.env.local
# In production (Vercel), set them as build env vars.
# ==========================================================================
# VITE_API_URL=https://org-ai-api-gateway.onrender.com/api
# VITE_WS_URL=wss://org-ai-api-gateway.onrender.com

# 注: ブラウザから LLM API を直接呼び出すことは禁止。LLM 呼び出しは必ず API Gateway 経由 (/api/llm/chat) で行う。
