GROQ_API_KEY=your_groq_api_key_here
# apps/web の .env.local: タスクマネージャーがブラウザから Groq を呼ぶときに必須
# VITE_GROQ_API_KEY=your_groq_api_key_here
# 未設定または false のとき llama-3.1-8b を使い TPM を節約。70B 優先するときのみ true
# VITE_GROQ_USE_LLAMA_70B=false
# タスクマネージャーで常にブラウザから Groq を叩く（429 時のデバッグ用）。通常は未設定のまま API 経由を推奨
# VITE_LLM_DIRECT_GROQ=false
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
DATABASE_URL=file:./data/app.db
FRONTEND_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:4000
AI_ENGINE_URL=http://localhost:8000
