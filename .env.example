# ==========================================================================
# FLOW / org-ai-platform — environment variables
# Copy this file to .env (local) and configure per environment.
# For production, set these in Vercel (web) and Render (gateway + ai-engine).
# ==========================================================================

# ------ Shared ------
NODE_ENV=development

# PostgreSQL (Neon in prod). Local dev can use docker-compose postgres.
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgresql://orgai:orgai-dev-password@localhost:5432/orgai

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_minimum_32_characters_required_xxxxxxxx

# ------ LLM provider (Anthropic Claude only) ------
# プラン別モデル: STARTER → Haiku 4.5, PRO → Sonnet 4.6, MAX → Opus 4.7
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------ 埋め込み / RAG (api-gateway) ------
# Anthropic に埋め込み API は無いため別プロバイダを使う。未設定なら RAG (ファイル根拠付け・
# 過去チャット横断参照) は静かに無効化され、チャットは従来通り動く。
# 出力次元は 1024 固定 (DB の vector(1024) と一致)。プロバイダ切替時もこの次元を維持すること。
#   - Voyage AI (推奨): EMBEDDING_PROVIDER=voyage / EMBEDDING_MODEL=voyage-3 (native 1024)
#   - OpenAI (代替):   EMBEDDING_PROVIDER=openai / EMBEDDING_MODEL=text-embedding-3-small (dimensions=1024)
# EMBEDDING_API_KEY=
# EMBEDDING_PROVIDER=voyage
# EMBEDDING_MODEL=voyage-3
# EMBEDDING_DIM=1024

# ------ Service URLs (server-to-server) ------
FRONTEND_URL=http://localhost:3000
API_GATEWAY_URL=http://localhost:4000
AI_ENGINE_URL=http://localhost:8000

# ------ n8n integration (optional) ------
# n8n を使う場合のみ設定。設定が無い・到達できない場合は AI Engine 単体で実行される。
#
# 起動方式 (どれか):
#   - Render: N8N_CLOUD_URL=https://org-ai-n8n-web.onrender.com
#   - n8n Cloud: N8N_CLOUD_URL=https://<tenant>.app.n8n.cloud
#   - ローカル: N8N_URL=http://localhost:5678 のみで OK (N8N_CLOUD_URL は未設定)
#
# Webhook 経由でワークフローを起動する設計に変更済み。dept-*.json をインポートし
# `Header Auth` クレデンシャル (Name: x-org-ai-token, Value: $N8N_WEBHOOK_AUTH_TOKEN) を
# 各 Webhook ノードに割り当ててからアクティブ化すること。
# N8N_URL=http://localhost:5678
# N8N_CLOUD_URL=https://org-ai-n8n-web.onrender.com
# N8N_API_KEY=                  # Public API キー (active ワークフローの判定に使用 / 任意)
# N8N_WEBHOOK_AUTH_TOKEN=       # Webhook Header Auth のトークン (n8n と一致させる)
# N8N_TIMEOUT_MS=30000          # capability-resolver から n8n webhook を叩く際のタイムアウト (ms)

# ------ Capability Registry ------
# 未対応 capability 要望時に Slack 通知が飛ぶチャンネル名 (notify_slack capability に渡す)
# ADMIN_SLACK_CHANNEL=#org-ai-admin

# ==========================================================================
# apps/web (Vite) build-time variables — put these in apps/web/.env.local
# In production (Vercel), set them as build env vars.
# ==========================================================================
# VITE_API_URL=https://org-ai-api-gateway.onrender.com/api
# VITE_WS_URL=wss://org-ai-api-gateway.onrender.com

# 注: ブラウザから LLM API を直接呼び出すことは禁止。LLM 呼び出しは必ず API Gateway 経由 (/api/llm/chat) で行う。
