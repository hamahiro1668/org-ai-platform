datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         String        @default("OWNER")
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Organization {
  id             String          @id @default(cuid())
  name           String
  plan           String          @default("STARTER")
  billingEmail   String?
  users          User[]
  sessions       ChatSession[]
  tasks          Task[]
  files          UploadedFile[]
  scheduledTasks ScheduledTask[]
  agents         Agent[]
  createdAt      DateTime        @default(now())
}

model ChatSession {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  title     String?
  messages  Message[]
  createdAt DateTime     @default(now())
}

model Message {
  id         String            @id @default(cuid())
  sessionId  String
  session    ChatSession       @relation(fields: [sessionId], references: [id])
  role       String
  content    String
  department String?
  createdAt  DateTime          @default(now())
  embedding  MessageEmbedding?
}

model Task {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id])
  title           String
  status          String       @default("PENDING")
  department      String
  taskType        String?
  input           String
  output          String?
  approvalData    String?
  n8nWorkflowId   String?
  executionResult String?
  retryCount      Int          @default(0)
  lastError       String?
  executedAt      DateTime?
  agentId         String?
  agent           Agent?       @relation(fields: [agentId], references: [id])
  logs            TaskLog[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([orgId, agentId])
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  message   String
  level     String   @default("INFO")
  createdAt DateTime @default(now())
}

model AILog {
  id         String   @id @default(cuid())
  orgId      String
  department String
  provider   String
  model      String
  inputText  String
  outputText String?
  tokens     Int?
  latencyMs  Int?
  riskScore  Float?
  createdAt  DateTime @default(now())
}

model RiskEvent {
  id          String   @id @default(cuid())
  orgId       String
  aiLogId     String?
  type        String
  description String
  severity    String
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model UploadedFile {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  uploadedBy   String
  originalName String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime     @default(now())
  chunks       FileChunk[]
}

/// RAG: アップロードファイルをチャンク分割し埋め込みベクトルを保持する。
/// embedding は pgvector の vector 型（Prisma 未対応のため Unsupported）。読み書きは $queryRaw / $executeRaw。
model FileChunk {
  id         String                  @id @default(cuid())
  orgId      String
  fileId     String
  file       UploadedFile            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime                @default(now())

  @@index([orgId])
  @@index([fileId])
}

/// RAG: チャットメッセージの埋め込み（過去履歴の横断参照用）。content を非正規化保持。
model MessageEmbedding {
  id        String                       @id @default(cuid())
  orgId     String
  messageId String                       @unique
  message   Message                      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  sessionId String
  role      String
  content   String
  embedding Unsupported("vector(1024)")?
  createdAt DateTime                     @default(now())

  @@index([orgId])
}

model ScheduledTask {
  id             String       @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id])
  title          String
  department     String
  taskType       String
  input          String
  recipientEmail String?
  frequency      String
  hourUtc        Int
  dayOfWeek      Int?
  dayOfMonth     Int?
  enabled        Boolean      @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([orgId, enabled])
}

enum CapabilityStatus {
  ACTIVE
  NEEDS_AUTH
  DISABLED
}

enum CredentialStatus {
  CONNECTED
  DISCONNECTED
}

model Capability {
  id            String               @id @default(cuid())
  orgId         String
  name          String
  displayName   String
  description   String
  department    String
  inputSchema   Json
  status        CapabilityStatus     @default(NEEDS_AUTH)
  n8nWorkflowId String?
  webhookPath   String?
  requiredCreds RequiredCredential[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([orgId, name])
  @@index([orgId, status])
}

model RequiredCredential {
  id            String           @id @default(cuid())
  capabilityId  String
  capability    Capability       @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  provider      String
  status        CredentialStatus @default(DISCONNECTED)
  lastCheckedAt DateTime?

  @@index([capabilityId])
}

model CapabilityGap {
  id           String   @id @default(cuid())
  orgId        String
  requestedBy  String
  rawRequest   String
  inferredName String?
  count        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, inferredName])
  @@index([orgId, createdAt])
}

model ExecutionLog {
  id           String   @id @default(cuid())
  orgId        String
  capabilityId String?
  status       String
  errorType    String?
  requestArgs  Json
  responseData Json?
  createdAt    DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([capabilityId])
}

enum AgentN8nStatus {
  PENDING // n8n ワークフロー未作成（API 不達 / スキップ）
  CREATED // 作成済みだが activate 未確認
  ACTIVE // 作成 + activate 済み
  FAILED // 生成を試みて失敗
  FALLBACK_ONLY // 意図的に n8n ワークフローを持たない（常に AI Engine で実行）
}

enum AgentTrigger {
  MANUAL
  SCHEDULED
}

/// ユーザーがチャット / フォームから作成する再利用可能な「業務効率化エージェント」。
/// DB の行が真実の源。n8n は best-effort の自動化レイヤーで、寝ていても AI Engine で実行される。
model Agent {
  id            String         @id @default(cuid())
  orgId         String
  org           Organization   @relation(fields: [orgId], references: [id])
  name          String
  description   String?
  department    String         @default("GENERAL")
  instructions  String // system プロンプト / ペルソナ
  steps         Json? // 順序付き capability ステップ: [{ capabilityName, argTemplate }]
  trigger       AgentTrigger   @default(MANUAL)
  enabled       Boolean        @default(true)
  // n8n linkage
  n8nWorkflowId String?
  webhookPath   String? // 例: "agent-<id>"
  n8nStatus     AgentN8nStatus @default(PENDING)
  // 表示用（保存エージェントを built-in と並べて描画するため）
  icon          String?
  color         String?
  createdBy     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tasks Task[]

  @@unique([orgId, name])
  @@index([orgId, enabled])
}
